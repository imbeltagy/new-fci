{
  "name": "server",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "pnpm swagger && tsx watch src/index.ts",
    "build": "pnpm swagger && prisma generate && tsc -p tsconfig.json",
    "start": "node dist/index.js",
    "swagger": "tsx src/swagger/generate.ts",
    "db:generate": "prisma generate",
    "db:migrate": "prisma migrate dev"
  },
  "dependencies": {
    "@prisma/client": "^6.10.1",
    "cors": "^2.8.6",
    "dotenv": "^17.4.2",
    "express": "^5.2.1",
    "ioredis": "^5.11.1",
    "swagger-ui-express": "^5.0.1"
  },
  "devDependencies": {
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/node": "^20.19.43",
    "@types/swagger-ui-express": "^4.1.8",
    "prisma": "^6.10.1",
    "swagger-autogen": "^2.23.7",
    "tsx": "^4.22.4",
    "typescript": "^5.9.3"
  }
}
