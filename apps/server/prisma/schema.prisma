datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

enum Role {
  student
  teacher
  sub_teacher @map("sub-teacher")
  it
  superadmin
}

enum Semester {
  first
  second
  summer
}

enum RoomType {
  community
  major_channel
  subject_channel
}

enum TicketStatus {
  pending
  in_review
  open
  rejected
  done
}

enum AssessmentType {
  quiz
  assignment
}

model File {
  id        String    @id @default(uuid())
  key       String    @unique
  url       String
  name      String
  size      Int
  mimeType  String    @map("mime_type")
  bucket    String
  createdAt DateTime  @default(now()) @map("created_at")
  deletedAt DateTime? @map("deleted_at")

  userAvatar     User?                    @relation("UserAvatar")
  userCover      User?                    @relation("UserCover")
  postImage      Post?                    @relation("PostImage")
  submissionFile AssignmentSubmissionFile? @relation("SubmissionFile")

  @@map("files")
}

model User {
  id                 String       @id @default(uuid())
  email              String       @unique
  passwordHash       String
  role               Role
  name               String
  avatarId           String?      @unique
  avatar             File?        @relation("UserAvatar", fields: [avatarId], references: [id], onDelete: SetNull)
  coverId            String?      @unique
  cover              File?        @relation("UserCover", fields: [coverId], references: [id], onDelete: SetNull)
  isActive           Boolean      @default(true)
  mustChangePassword Boolean      @default(true)
  tempPassword       String?
  sendOnce           Boolean      @default(false)
  whatsapp           String?
  accessGroupId      String?
  accessGroup        AccessGroup? @relation(fields: [accessGroupId], references: [id], onDelete: SetNull)
  joinYearId         String?
  joinYear           JoinYear?    @relation(fields: [joinYearId], references: [id], onDelete: SetNull)
  majorId            String?
  major              Major?       @relation(fields: [majorId], references: [id], onDelete: SetNull)
  createdAt          DateTime     @default(now())
  updatedAt          DateTime     @updatedAt

  passwordResetTokens      PasswordResetToken[]
  staffJoinYearAssignments StaffJoinYearAssignment[]
  staffMajorAssignments    StaffMajorAssignment[]
  staffSubjectAssignments  StaffSubjectAssignment[]
  subjectEnrollments       SubjectEnrollment[]
  posts                    Post[]
  comments                 Comment[]
  postLikes                PostLike[]
  mutedRooms               MutedUser[]
  conversationsAsUser1     Conversation[]            @relation("ConvUser1")
  conversationsAsUser2     Conversation[]            @relation("ConvUser2")
  directMessages           DirectMessage[]
  tickets                  Ticket[]
  ticketMessages           TicketMessage[]
  createdAssessments       Assessment[]          @relation("AssessmentCreator")
  quizSubmissions          QuizSubmission[]      @relation("QuizStudent")
  assignmentSubmissions    AssignmentSubmission[] @relation("AssignmentStudent")

  @@map("users")
}

model AccessGroup {
  id          String       @id @default(uuid())
  name        String
  description String?
  permissions Permission[]
  users       User[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("access_groups")
}

model Permission {
  id            String      @id @default(uuid())
  key           String
  accessGroupId String
  accessGroup   AccessGroup @relation(fields: [accessGroupId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())

  @@unique([key, accessGroupId])
  @@index([accessGroupId])
  @@map("permissions")
}

model PasswordResetToken {
  id        String    @id @default(uuid())
  tokenHash String    @unique
  userId    String
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime  @default(now())

  @@map("password_reset_tokens")
}

model JoinYear {
  id        String   @id @default(uuid())
  year      Int      @unique
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  users                    User[]
  subjects                 Subject[]
  staffJoinYearAssignments StaffJoinYearAssignment[]
  staffMajorAssignments    StaffMajorAssignment[]
  rooms                    Room[]

  @@map("join_years")
}

model Major {
  id        String   @id @default(uuid())
  name      String
  code      String   @unique
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  users                 User[]
  subjects              Subject[]
  staffMajorAssignments StaffMajorAssignment[]
  rooms                 Room[]

  @@map("majors")
}

model Subject {
  id         String   @id @default(uuid())
  code       String   @unique
  name       String
  semester   Semester
  joinYearId String
  joinYear   JoinYear @relation(fields: [joinYearId], references: [id], onDelete: Cascade)
  majorId    String
  major      Major    @relation(fields: [majorId], references: [id], onDelete: Cascade)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  enrollments      SubjectEnrollment[]
  staffAssignments StaffSubjectAssignment[]
  room             Room?
  assessments      Assessment[]

  @@map("subjects")
}

model StaffJoinYearAssignment {
  id         String   @id @default(uuid())
  userId     String
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  joinYearId String
  joinYear   JoinYear @relation(fields: [joinYearId], references: [id], onDelete: Cascade)
  createdAt  DateTime @default(now())

  @@unique([userId, joinYearId])
  @@map("staff_join_year_assignments")
}

model StaffMajorAssignment {
  id         String   @id @default(uuid())
  userId     String
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  majorId    String
  major      Major    @relation(fields: [majorId], references: [id], onDelete: Cascade)
  joinYearId String
  joinYear   JoinYear @relation(fields: [joinYearId], references: [id], onDelete: Cascade)
  createdAt  DateTime @default(now())

  @@unique([userId, majorId, joinYearId])
  @@map("staff_major_assignments")
}

model StaffSubjectAssignment {
  id        String   @id @default(uuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  subjectId String
  subject   Subject  @relation(fields: [subjectId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())

  @@unique([userId, subjectId])
  @@map("staff_subject_assignments")
}

model SubjectEnrollment {
  id        String   @id @default(uuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  subjectId String
  subject   Subject  @relation(fields: [subjectId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())

  @@unique([userId, subjectId])
  @@map("subject_enrollments")
}

model Room {
  id         String    @id @default(uuid())
  name       String
  type       RoomType
  joinYearId String?
  joinYear   JoinYear? @relation(fields: [joinYearId], references: [id], onDelete: Cascade)
  majorId    String?
  major      Major?    @relation(fields: [majorId], references: [id], onDelete: Cascade)
  subjectId  String?   @unique
  subject    Subject?  @relation(fields: [subjectId], references: [id], onDelete: Cascade)
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt

  posts      Post[]
  mutedUsers MutedUser[]

  @@unique([type, joinYearId, majorId])
  @@index([joinYearId])
  @@index([majorId])
  @@map("rooms")
}

model Post {
  id        String    @id @default(uuid())
  roomId    String
  room      Room      @relation(fields: [roomId], references: [id], onDelete: Cascade)
  authorId  String
  author    User      @relation(fields: [authorId], references: [id], onDelete: Cascade)
  content   String
  imageId   String?   @unique
  image     File?     @relation("PostImage", fields: [imageId], references: [id], onDelete: SetNull)
  likeCount Int       @default(0)
  deletedAt DateTime?
  createdAt DateTime  @default(now())

  comments Comment[]
  likes    PostLike[]
  pinned   PinnedPost?

  @@index([roomId, createdAt])
  @@map("posts")
}

model PostLike {
  id        String   @id @default(uuid())
  postId    String
  post      Post     @relation(fields: [postId], references: [id], onDelete: Cascade)
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())

  @@unique([postId, userId])
  @@index([postId])
  @@map("post_likes")
}

model Comment {
  id        String    @id @default(uuid())
  postId    String
  post      Post      @relation(fields: [postId], references: [id], onDelete: Cascade)
  authorId  String
  author    User      @relation(fields: [authorId], references: [id], onDelete: Cascade)
  content   String
  parentId  String?
  parent    Comment?  @relation("CommentReplies", fields: [parentId], references: [id], onDelete: Cascade)
  replies   Comment[] @relation("CommentReplies")
  deletedAt DateTime?
  createdAt DateTime  @default(now())

  @@index([postId, createdAt])
  @@map("comments")
}

model PinnedPost {
  id         String   @id @default(uuid())
  roomId     String
  postId     String   @unique
  post       Post     @relation(fields: [postId], references: [id], onDelete: Cascade)
  pinnedById String
  createdAt  DateTime @default(now())

  @@index([roomId])
  @@map("pinned_posts")
}

model MutedUser {
  id         String    @id @default(uuid())
  roomId     String
  room       Room      @relation(fields: [roomId], references: [id], onDelete: Cascade)
  userId     String
  user       User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  mutedUntil DateTime?
  createdAt  DateTime  @default(now())

  @@unique([roomId, userId])
  @@map("muted_users")
}

model Conversation {
  id        String   @id @default(uuid())
  user1Id   String
  user1     User     @relation("ConvUser1", fields: [user1Id], references: [id], onDelete: Cascade)
  user2Id   String
  user2     User     @relation("ConvUser2", fields: [user2Id], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  messages DirectMessage[]

  @@unique([user1Id, user2Id])
  @@map("conversations")
}

model DirectMessage {
  id             String       @id @default(uuid())
  conversationId String
  conversation   Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  senderId       String
  sender         User         @relation(fields: [senderId], references: [id], onDelete: Cascade)
  content        String
  readAt         DateTime?
  createdAt      DateTime     @default(now())

  @@index([conversationId, createdAt])
  @@map("direct_messages")
}

model Ticket {
  id              String       @id @default(uuid())
  clientId        String
  client          User         @relation(fields: [clientId], references: [id], onDelete: Cascade)
  title           String
  body            String
  status          TicketStatus @default(pending)
  rejectionReason String?
  createdAt       DateTime     @default(now())
  updatedAt       DateTime     @updatedAt

  messages TicketMessage[]

  @@index([clientId])
  @@map("tickets")
}

model TicketMessage {
  id        String   @id @default(uuid())
  ticketId  String
  ticket    Ticket   @relation(fields: [ticketId], references: [id], onDelete: Cascade)
  senderId  String
  sender    User     @relation(fields: [senderId], references: [id], onDelete: Cascade)
  content   String
  isItSide  Boolean
  createdAt DateTime @default(now())

  @@index([ticketId, createdAt])
  @@map("ticket_messages")
}

model Assessment {
  id           String         @id @default(uuid())
  type         AssessmentType
  subjectId    String         @map("subject_id")
  subject      Subject        @relation(fields: [subjectId], references: [id], onDelete: Cascade)
  creatorId    String         @map("creator_id")
  creator      User           @relation("AssessmentCreator", fields: [creatorId], references: [id], onDelete: Cascade)
  title        String
  startDate    DateTime       @map("start_date")
  endDate      DateTime       @map("end_date")
  isVisible    Boolean        @default(false) @map("is_visible")
  publishedAt  DateTime?      @map("published_at")
  markReadable Boolean        @default(false) @map("mark_readable")
  createdAt    DateTime       @default(now()) @map("created_at")
  updatedAt    DateTime       @updatedAt @map("updated_at")

  quiz                  Quiz?
  assignmentDetails     AssignmentDetails?
  quizSubmissions       QuizSubmission[]
  assignmentSubmissions AssignmentSubmission[]

  @@index([subjectId])
  @@map("assessments")
}

model Quiz {
  assessmentId String     @id @map("assessment_id")
  assessment   Assessment @relation(fields: [assessmentId], references: [id], onDelete: Cascade)

  questions QuizQuestion[]

  @@map("quizzes")
}

model QuizQuestion {
  id            String   @id @default(uuid())
  quizId        String   @map("quiz_id")
  quiz          Quiz     @relation(fields: [quizId], references: [assessmentId], onDelete: Cascade)
  text          String
  degree        Int      @default(1)
  correctOption Int      @map("correct_option")
  createdAt     DateTime @default(now()) @map("created_at")

  options QuizOption[]
  answers QuizAnswer[]

  @@index([quizId])
  @@map("quiz_questions")
}

model QuizOption {
  id         String       @id @default(uuid())
  questionId String       @map("question_id")
  question   QuizQuestion @relation(fields: [questionId], references: [id], onDelete: Cascade)
  text       String
  index      Int

  @@index([questionId])
  @@map("quiz_options")
}

model QuizSubmission {
  id           String   @id @default(uuid())
  assessmentId String   @map("assessment_id")
  assessment   Assessment @relation(fields: [assessmentId], references: [id], onDelete: Cascade)
  studentId    String   @map("student_id")
  student      User     @relation("QuizStudent", fields: [studentId], references: [id], onDelete: Cascade)
  mark         Int
  submittedAt  DateTime @default(now()) @map("submitted_at")

  answers QuizAnswer[]

  @@unique([assessmentId, studentId])
  @@index([assessmentId])
  @@map("quiz_submissions")
}

model QuizAnswer {
  id             String         @id @default(uuid())
  submissionId   String         @map("submission_id")
  submission     QuizSubmission @relation(fields: [submissionId], references: [id], onDelete: Cascade)
  questionId     String         @map("question_id")
  question       QuizQuestion   @relation(fields: [questionId], references: [id], onDelete: Cascade)
  selectedOption Int            @map("selected_option")
  isCorrect      Boolean        @map("is_correct")

  @@unique([submissionId, questionId])
  @@index([submissionId])
  @@map("quiz_answers")
}

model AssignmentDetails {
  assessmentId String     @id @map("assessment_id")
  assessment   Assessment @relation(fields: [assessmentId], references: [id], onDelete: Cascade)
  totalMark    Int        @map("total_mark")

  @@map("assignment_details")
}

model AssignmentSubmission {
  id           String     @id @default(uuid())
  assessmentId String     @map("assessment_id")
  assessment   Assessment @relation(fields: [assessmentId], references: [id], onDelete: Cascade)
  studentId    String     @map("student_id")
  student      User       @relation("AssignmentStudent", fields: [studentId], references: [id], onDelete: Cascade)
  mark         Int?
  submittedAt  DateTime   @default(now()) @map("submitted_at")
  updatedAt    DateTime   @updatedAt @map("updated_at")

  files AssignmentSubmissionFile[]

  @@unique([assessmentId, studentId])
  @@index([assessmentId])
  @@map("assignment_submissions")
}

model AssignmentSubmissionFile {
  id           String               @id @default(uuid())
  submissionId String               @map("submission_id")
  submission   AssignmentSubmission @relation(fields: [submissionId], references: [id], onDelete: Cascade)
  fileId       String               @unique @map("file_id")
  file         File                 @relation("SubmissionFile", fields: [fileId], references: [id], onDelete: Cascade)
  createdAt    DateTime             @default(now()) @map("created_at")

  @@index([submissionId])
  @@map("assignment_submission_files")
}
