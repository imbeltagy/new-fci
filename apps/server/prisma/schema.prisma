datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

enum Role {
  student
  teacher
  sub_teacher @map("sub-teacher")
  it
  superadmin
}

enum Semester {
  first
  second
  summer
}

enum RoomType {
  community
  major_channel
  subject_channel
}

enum TicketStatus {
  pending
  in_review
  open
  rejected
  done
}

model File {
  id        String    @id @default(uuid())
  key       String    @unique
  url       String
  name      String
  size      Int
  mimeType  String    @map("mime_type")
  bucket    String
  createdAt DateTime  @default(now()) @map("created_at")
  deletedAt DateTime? @map("deleted_at")

  userAvatar User? @relation("UserAvatar")
  userCover  User? @relation("UserCover")

  @@map("files")
}

model User {
  id                 String       @id @default(uuid())
  email              String       @unique
  passwordHash       String
  role               Role
  name               String
  avatarId           String?      @unique
  avatar             File?        @relation("UserAvatar", fields: [avatarId], references: [id], onDelete: SetNull)
  coverId            String?      @unique
  cover              File?        @relation("UserCover", fields: [coverId], references: [id], onDelete: SetNull)
  isActive           Boolean      @default(true)
  mustChangePassword Boolean      @default(true)
  tempPassword       String?
  sendOnce           Boolean      @default(false)
  whatsapp           String?
  accessGroupId      String?
  accessGroup        AccessGroup? @relation(fields: [accessGroupId], references: [id], onDelete: SetNull)
  joinYearId         String?
  joinYear           JoinYear?    @relation(fields: [joinYearId], references: [id], onDelete: SetNull)
  majorId            String?
  major              Major?       @relation(fields: [majorId], references: [id], onDelete: SetNull)
  createdAt          DateTime     @default(now())
  updatedAt          DateTime     @updatedAt

  passwordResetTokens      PasswordResetToken[]
  staffJoinYearAssignments StaffJoinYearAssignment[]
  staffMajorAssignments    StaffMajorAssignment[]
  staffSubjectAssignments  StaffSubjectAssignment[]
  subjectEnrollments       SubjectEnrollment[]
  messages                 Message[]
  mutedRooms               MutedUser[]
  conversationsAsUser1     Conversation[]            @relation("ConvUser1")
  conversationsAsUser2     Conversation[]            @relation("ConvUser2")
  directMessages           DirectMessage[]
  tickets                  Ticket[]
  ticketMessages           TicketMessage[]

  @@map("users")
}

model AccessGroup {
  id          String       @id @default(uuid())
  name        String
  description String?
  permissions Permission[]
  users       User[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("access_groups")
}

model Permission {
  id            String      @id @default(uuid())
  key           String
  accessGroupId String
  accessGroup   AccessGroup @relation(fields: [accessGroupId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())

  @@unique([key, accessGroupId])
  @@index([accessGroupId])
  @@map("permissions")
}

model PasswordResetToken {
  id        String    @id @default(uuid())
  tokenHash String    @unique
  userId    String
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime  @default(now())

  @@map("password_reset_tokens")
}

model JoinYear {
  id        String   @id @default(uuid())
  year      Int      @unique
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  users                    User[]
  subjects                 Subject[]
  staffJoinYearAssignments StaffJoinYearAssignment[]
  staffMajorAssignments    StaffMajorAssignment[]
  rooms                    Room[]

  @@map("join_years")
}

model Major {
  id        String   @id @default(uuid())
  name      String
  code      String   @unique
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  users                 User[]
  subjects              Subject[]
  staffMajorAssignments StaffMajorAssignment[]
  rooms                 Room[]

  @@map("majors")
}

model Subject {
  id         String   @id @default(uuid())
  code       String   @unique
  name       String
  semester   Semester
  joinYearId String
  joinYear   JoinYear @relation(fields: [joinYearId], references: [id], onDelete: Cascade)
  majorId    String
  major      Major    @relation(fields: [majorId], references: [id], onDelete: Cascade)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  enrollments      SubjectEnrollment[]
  staffAssignments StaffSubjectAssignment[]
  room             Room?

  @@map("subjects")
}

model StaffJoinYearAssignment {
  id         String   @id @default(uuid())
  userId     String
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  joinYearId String
  joinYear   JoinYear @relation(fields: [joinYearId], references: [id], onDelete: Cascade)
  createdAt  DateTime @default(now())

  @@unique([userId, joinYearId])
  @@map("staff_join_year_assignments")
}

model StaffMajorAssignment {
  id         String   @id @default(uuid())
  userId     String
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  majorId    String
  major      Major    @relation(fields: [majorId], references: [id], onDelete: Cascade)
  joinYearId String
  joinYear   JoinYear @relation(fields: [joinYearId], references: [id], onDelete: Cascade)
  createdAt  DateTime @default(now())

  @@unique([userId, majorId, joinYearId])
  @@map("staff_major_assignments")
}

model StaffSubjectAssignment {
  id        String   @id @default(uuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  subjectId String
  subject   Subject  @relation(fields: [subjectId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())

  @@unique([userId, subjectId])
  @@map("staff_subject_assignments")
}

model SubjectEnrollment {
  id        String   @id @default(uuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  subjectId String
  subject   Subject  @relation(fields: [subjectId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())

  @@unique([userId, subjectId])
  @@map("subject_enrollments")
}

model Room {
  id         String    @id @default(uuid())
  name       String
  type       RoomType
  joinYearId String?
  joinYear   JoinYear? @relation(fields: [joinYearId], references: [id], onDelete: Cascade)
  majorId    String?
  major      Major?    @relation(fields: [majorId], references: [id], onDelete: Cascade)
  subjectId  String?   @unique
  subject    Subject?  @relation(fields: [subjectId], references: [id], onDelete: Cascade)
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt

  messages   Message[]
  mutedUsers MutedUser[]

  @@unique([type, joinYearId, majorId])
  @@index([joinYearId])
  @@index([majorId])
  @@map("rooms")
}

model Message {
  id        String    @id @default(uuid())
  roomId    String
  room      Room      @relation(fields: [roomId], references: [id], onDelete: Cascade)
  senderId  String
  sender    User      @relation(fields: [senderId], references: [id], onDelete: Cascade)
  content   String
  deletedAt DateTime?
  createdAt DateTime  @default(now())

  pinned PinnedMessage?

  @@index([roomId, createdAt])
  @@map("messages")
}

model PinnedMessage {
  id         String   @id @default(uuid())
  roomId     String
  messageId  String   @unique
  message    Message  @relation(fields: [messageId], references: [id], onDelete: Cascade)
  pinnedById String
  createdAt  DateTime @default(now())

  @@index([roomId])
  @@map("pinned_messages")
}

model MutedUser {
  id         String    @id @default(uuid())
  roomId     String
  room       Room      @relation(fields: [roomId], references: [id], onDelete: Cascade)
  userId     String
  user       User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  mutedUntil DateTime?
  createdAt  DateTime  @default(now())

  @@unique([roomId, userId])
  @@map("muted_users")
}

model Conversation {
  id        String   @id @default(uuid())
  user1Id   String
  user1     User     @relation("ConvUser1", fields: [user1Id], references: [id], onDelete: Cascade)
  user2Id   String
  user2     User     @relation("ConvUser2", fields: [user2Id], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  messages DirectMessage[]

  @@unique([user1Id, user2Id])
  @@map("conversations")
}

model DirectMessage {
  id             String       @id @default(uuid())
  conversationId String
  conversation   Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  senderId       String
  sender         User         @relation(fields: [senderId], references: [id], onDelete: Cascade)
  content        String
  readAt         DateTime?
  createdAt      DateTime     @default(now())

  @@index([conversationId, createdAt])
  @@map("direct_messages")
}

model Ticket {
  id              String       @id @default(uuid())
  clientId        String
  client          User         @relation(fields: [clientId], references: [id], onDelete: Cascade)
  title           String
  body            String
  status          TicketStatus @default(pending)
  rejectionReason String?
  createdAt       DateTime     @default(now())
  updatedAt       DateTime     @updatedAt

  messages TicketMessage[]

  @@index([clientId])
  @@map("tickets")
}

model TicketMessage {
  id        String   @id @default(uuid())
  ticketId  String
  ticket    Ticket   @relation(fields: [ticketId], references: [id], onDelete: Cascade)
  senderId  String
  sender    User     @relation(fields: [senderId], references: [id], onDelete: Cascade)
  content   String
  isItSide  Boolean
  createdAt DateTime @default(now())

  @@index([ticketId, createdAt])
  @@map("ticket_messages")
}
