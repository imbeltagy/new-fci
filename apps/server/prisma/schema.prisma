datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

enum Role {
  student
  teacher
  sub_teacher @map("sub-teacher")
  it
  superadmin
}

enum Semester {
  first
  second
  summer
}

model File {
  id        String    @id @default(uuid())
  key       String    @unique
  url       String
  name      String
  size      Int
  mimeType  String    @map("mime_type")
  bucket    String
  createdAt DateTime  @default(now()) @map("created_at")
  deletedAt DateTime? @map("deleted_at")

  userAvatar User? @relation("UserAvatar")
  userCover  User? @relation("UserCover")

  @@map("files")
}

model User {
  id                 String       @id @default(uuid())
  email              String       @unique
  passwordHash       String
  role               Role
  name               String
  avatarId           String?      @unique
  avatar             File?        @relation("UserAvatar", fields: [avatarId], references: [id], onDelete: SetNull)
  coverId            String?      @unique
  cover              File?        @relation("UserCover", fields: [coverId], references: [id], onDelete: SetNull)
  isActive           Boolean      @default(true)
  mustChangePassword Boolean      @default(true)
  tempPassword       String?
  sendOnce           Boolean      @default(false)
  whatsapp           String?
  accessGroupId      String?
  accessGroup        AccessGroup? @relation(fields: [accessGroupId], references: [id], onDelete: SetNull)
  joinYearId         String?
  joinYear           JoinYear?    @relation(fields: [joinYearId], references: [id], onDelete: SetNull)
  majorId            String?
  major              Major?       @relation(fields: [majorId], references: [id], onDelete: SetNull)
  createdAt          DateTime     @default(now())
  updatedAt          DateTime     @updatedAt

  passwordResetTokens      PasswordResetToken[]
  staffJoinYearAssignments StaffJoinYearAssignment[]
  staffMajorAssignments    StaffMajorAssignment[]
  staffSubjectAssignments  StaffSubjectAssignment[]
  subjectEnrollments       SubjectEnrollment[]

  @@map("users")
}

model AccessGroup {
  id          String       @id @default(uuid())
  name        String
  description String?
  permissions Permission[]
  users       User[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("access_groups")
}

model Permission {
  id            String      @id @default(uuid())
  key           String
  accessGroupId String
  accessGroup   AccessGroup @relation(fields: [accessGroupId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())

  @@unique([key, accessGroupId])
  @@index([accessGroupId])
  @@map("permissions")
}

model PasswordResetToken {
  id        String    @id @default(uuid())
  tokenHash String    @unique
  userId    String
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime  @default(now())

  @@map("password_reset_tokens")
}

model JoinYear {
  id        String   @id @default(uuid())
  year      Int      @unique
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  users                    User[]
  subjects                 Subject[]
  staffJoinYearAssignments StaffJoinYearAssignment[]
  staffMajorAssignments    StaffMajorAssignment[]

  @@map("join_years")
}

model Major {
  id        String   @id @default(uuid())
  name      String
  code      String   @unique
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  users                 User[]
  subjects              Subject[]
  staffMajorAssignments StaffMajorAssignment[]

  @@map("majors")
}

model Subject {
  id         String   @id @default(uuid())
  code       String   @unique
  name       String
  semester   Semester
  joinYearId String
  joinYear   JoinYear @relation(fields: [joinYearId], references: [id], onDelete: Cascade)
  majorId    String
  major      Major    @relation(fields: [majorId], references: [id], onDelete: Cascade)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  enrollments      SubjectEnrollment[]
  staffAssignments StaffSubjectAssignment[]

  @@map("subjects")
}

model StaffJoinYearAssignment {
  id         String   @id @default(uuid())
  userId     String
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  joinYearId String
  joinYear   JoinYear @relation(fields: [joinYearId], references: [id], onDelete: Cascade)
  createdAt  DateTime @default(now())

  @@unique([userId, joinYearId])
  @@map("staff_join_year_assignments")
}

model StaffMajorAssignment {
  id         String   @id @default(uuid())
  userId     String
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  majorId    String
  major      Major    @relation(fields: [majorId], references: [id], onDelete: Cascade)
  joinYearId String
  joinYear   JoinYear @relation(fields: [joinYearId], references: [id], onDelete: Cascade)
  createdAt  DateTime @default(now())

  @@unique([userId, majorId, joinYearId])
  @@map("staff_major_assignments")
}

model StaffSubjectAssignment {
  id        String   @id @default(uuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  subjectId String
  subject   Subject  @relation(fields: [subjectId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())

  @@unique([userId, subjectId])
  @@map("staff_subject_assignments")
}

model SubjectEnrollment {
  id        String   @id @default(uuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  subjectId String
  subject   Subject  @relation(fields: [subjectId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())

  @@unique([userId, subjectId])
  @@map("subject_enrollments")
}
